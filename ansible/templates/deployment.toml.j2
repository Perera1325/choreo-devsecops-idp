# WSO2 API Manager / Identity Server Deployment Configuration Template
# Autogenerated by Ansible DevSecOps Platform Provisioner

[server]
hostname = "{{ ansible_host }}"
node_ip = "{{ ansible_host }}"
avatar = "https://wso2.com/assets/img/wso2-logo.svg"

[admin]
username = "{{ apim_admin_user }}"
password = "{{ apim_admin_pass }}"

# Configure PostgreSQL Database Connectivity for WSO2 APIM and IS Meta Stores
[[database]]
id = "shared_db"
url = "jdbc:postgresql://{{ db_host }}:{{ db_port }}/wso2shared"
username = "{{ db_user }}"
password = "{{ db_pass }}"
driver = "org.postgresql.Driver"
db_properties = {maxActive = 80, maxWait = 60000, minIdle = 5, testOnBorrow = true, validationQuery = "SELECT 1", validationInterval = 30000}

[[database]]
id = "apim_db"
url = "jdbc:postgresql://{{ db_host }}:{{ db_port }}/wso2am_db"
username = "{{ db_user }}"
password = "{{ db_pass }}"
driver = "org.postgresql.Driver"
db_properties = {maxActive = 50, maxWait = 60000, minIdle = 5, testOnBorrow = true, validationQuery = "SELECT 1", validationInterval = 30000}

# Configure OAuth2 Keystore for JWT Issuance and WSO2 Identity Server Validation
[keystore.primary]
file_name = "repository/resources/security/wso2carbon.jks"
type = "JKS"
password = "identitykeystorepassword"
alias = "wso2carbon"
key_password = "identitykeypassword"

# Enable JWT Token Generation in API Gateway for Downstream Microservices Auth
[apim.jwt]
enable = true
header = "X-JWT-Assertion"
signing_algorithm = "SHA256withRSA"
enable_user_claims = true
claims_extractor = "org.wso2.carbon.apimgt.impl.token.DefaultClaimsExtractor"

# Enable CORS configurations globally for IDP Dashboard integration
[cors]
allow_origins = ["http://localhost:5173", "http://localhost:3000"]
allow_methods = ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
allow_headers = ["Authorization", "Content-Type", "X-JWT-Assertion"]
allow_credentials = true
